# ===== flkr backend env =====
# Copy to .env and adjust values.

# Server
PORT=8787
NODE_ENV=production

# Public origin(s) allowed by CORS (comma-separated, no trailing slash).
# In production, set this to your deployed frontend domain.
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://flkr.app,https://www.flkr.app

# Admin fallback password (also still requires OTP).
ADMIN_FALLBACK_PASSWORD=flkr2026

# OTP target inbox. Codes are emailed here.
OTP_RECIPIENT=wisdomobialo22@gmail.com

# SMTP credentials (use a Gmail App Password — never your real password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-sender@gmail.com
SMTP_PASS=your-16-char-app-password

# JWT signing secret (rotate on deploy).
JWT_SECRET=change-me-to-a-32-char-random-string
JWT_TTL_SECONDS=3600

# Rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
OTP_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_MAX=5

# Lockout
LOCKOUT_THRESHOLD=3
LOCKOUT_DURATION_MS=60000

# DB
DB_PATH=./flkr.sqlite
